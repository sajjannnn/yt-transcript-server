{
  "name": "yt-transcript-api",
  "version": "1.0.8",
  "description": "A lightweight JavaScript API and CLI for retrieving YouTube video transcripts and subtitles (including auto-generated and translated ones). No headless browsers required.",
  "main": "src/index.js",
  "bin": {
    "youtube-transcript-api": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "cli": "node src/cli.js",
    "build": "esbuild src/index.js --bundle --platform=node --outfile=dist/bundle.js",
    "lint": "npx eslint ./src"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chintamani-pala/youtube-transcript-js.git"
  },
  "keywords": [
    "youtube",
    "transcript",
    "subtitles",
    "api",
    "cli",
    "captions",
    "nodejs"
  ],
  "author": "Chintamani Pala",
  "license": "MIT",
  "private": false,
  "dependencies": {
    "axios": "^1.6.8",
    "fast-xml-parser": "^4.3.5",
    "he": "^1.2.0",
    "minimist": "^1.2.8"
  },
  "devDependencies": {
    "esbuild": "^0.25.5",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}